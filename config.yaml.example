# CockroachDB Operator VKS Functional Test Configuration
# Copy this file to config.yaml and update with your environment values

# =============================================================================
# VMware Supervisor Configuration
# =============================================================================
supervisor:
  ip: "10.0.0.100"                          # Supervisor cluster IP address
  username: "administrator@vsphere.local"   # vSphere SSO username
  namespace: "vks-namespace"                # Supervisor namespace for VKS cluster
  context: "supervisor-context"             # kubectl context name for supervisor

# =============================================================================
# VKS Cluster Configuration
# =============================================================================
vks_cluster:
  name: "cluster-vks"                       # VKS cluster name
  namespace: "crdb-cluster"                 # Namespace for CockroachDB within VKS
  context: "cluster-vks-context"            # kubectl context name for VKS cluster
  kubeconfig: "vks-kubeconfig.yaml"         # Path to VKS kubeconfig file
  version: "v1.35.0+vmware.2-vkr.4"         # VKS Kubernetes version
  version_upgrade: "v1.36.0+vmware.1-vkr.1" # Target version for upgrade tests

# =============================================================================
# CockroachDB Operator Configuration
# =============================================================================
operator:
  namespace: "crdb-operator"                # Namespace for operator deployment
  helm_chart_path: "./cockroachdb-parent/charts/operator"  # Path to operator Helm chart
  version: "2.14.0"                         # Operator version (for upgrade tests)
  version_upgrade: "2.15.0"                 # Target operator version for upgrade

# =============================================================================
# CockroachDB Cluster Configuration
# =============================================================================
cockroachdb:
  namespace: "crdb-cluster"                 # Namespace for CockroachDB cluster
  helm_chart_path: "./cockroachdb-parent/charts/cockroachdb"  # Path to CockroachDB Helm chart
  release_name: "cockroachdb"               # Helm release name
  
  # Version configuration for upgrade tests
  version:
    current: "v24.2.0"                      # Current CockroachDB version
    patch_upgrade: "v24.2.1"                # Target version for patch upgrade
    major_upgrade: "v24.3.0"                # Target version for major upgrade
    rollback: "v24.2.0"                     # Version to rollback to
  
  # Cluster sizing
  replicas:
    initial: 3                              # Initial number of replicas
    scale_up: 6                             # Replicas after scale up
    scale_down: 3                           # Replicas after scale down
  
  # Storage configuration
  storage:
    class: "vsan-esa-default-policy-raid5"  # Storage class for PVCs
    size: "100Gi"                           # PVC size
    wal_storage_class: "vsan-esa-default-policy-raid5"  # Storage class for WAL
    wal_size: "10Gi"                        # WAL PVC size
  
  # TLS configuration
  tls:
    enabled: true                           # Enable TLS
    ca_secret: "cockroachdb-ca"             # CA secret name
    node_secret: "cockroachdb-node"         # Node certificate secret name
    client_secret: "cockroachdb-client"     # Client certificate secret name
  
  # Resource limits
  resources:
    requests:
      cpu: "2"
      memory: "8Gi"
    limits:
      cpu: "4"
      memory: "16Gi"

# =============================================================================
# Networking Configuration
# =============================================================================
networking:
  sql_port: 26257                           # SQL port
  http_port: 8080                           # HTTP/Admin UI port
  grpc_port: 26258                          # gRPC port (inter-node)
  
  # LoadBalancer configuration (if applicable)
  loadbalancer:
    enabled: false                          # Enable LoadBalancer service
    annotations: {}                         # LoadBalancer annotations
  
  # NetworkPolicy configuration
  network_policy:
    enabled: true                           # Enable NetworkPolicy

# =============================================================================
# Backup Configuration
# =============================================================================
backup:
  # Local backup (nodelocal)
  local:
    enabled: true
    path: "nodelocal://1/backups"
  
  # S3-compatible storage (optional)
  s3:
    enabled: false
    bucket: "crdb-backups"
    endpoint: "https://s3.amazonaws.com"
    region: "us-west-2"
    access_key_id: ""                       # Leave empty, use secrets
    secret_access_key: ""                   # Leave empty, use secrets
  
  # GCS (optional)
  gcs:
    enabled: false
    bucket: "crdb-backups"
    credentials_json: ""                    # Path to service account JSON

# =============================================================================
# Advanced Features Configuration
# =============================================================================
advanced_features:
  # Physical Cluster Replication (PCR)
  pcr:
    enabled: false
    standby_cluster_name: "cockroachdb-standby"
    standby_namespace: "crdb-standby"
  
  # Encryption at Rest
  encryption:
    enabled: false
    kms_type: "aws"                         # aws, gcp, or azure
    kms_uri: ""                             # KMS key URI
  
  # CDC (Change Data Capture)
  cdc:
    enabled: false
    sink_type: "kafka"                      # kafka, pubsub, webhook
    kafka_brokers: ""                       # Kafka broker addresses
    pubsub_project: ""                      # GCP project for Pub/Sub

# =============================================================================
# Test Execution Configuration
# =============================================================================
test_config:
  # Timeouts (in seconds)
  timeouts:
    cluster_provision: 900                  # VKS cluster provisioning timeout
    pod_ready: 600                          # Pod ready timeout
    helm_install: 600                       # Helm install timeout
    scale_operation: 1800                   # Scale up/down timeout
    upgrade: 1800                           # Upgrade timeout
    backup: 300                             # Backup operation timeout
    restore: 600                            # Restore operation timeout
  
  # Retry configuration
  retries:
    max_attempts: 3                         # Maximum retry attempts
    delay_seconds: 30                       # Delay between retries
  
  # Cleanup behavior
  cleanup:
    on_success: false                       # Cleanup resources after successful tests
    on_failure: false                       # Cleanup resources after failed tests

# =============================================================================
# Monitoring Configuration (optional)
# =============================================================================
monitoring:
  prometheus:
    enabled: false
    namespace: "monitoring"
    service_monitor: true                   # Create ServiceMonitor CRD
  
  grafana:
    enabled: false
    namespace: "monitoring"
